{
  "expo": {
    "name": "nexpo",
    "slug": "nexpo",
    "version": "1.0.0",
    "scheme": "nexpo",
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "com.nexpo.app"
    },
    "plugins": [
      "expo-localization",
      "@sentry/react-native",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "backgroundColor": "#ffffff",
          "resizeMode": "contain"
        }
      ],
      "expo-status-bar"
    ],
    "android": {
      "package": "com.nexpo.app"
    }
  }
}
