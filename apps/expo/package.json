{
  "dependencies": {
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "2.108.1",
    "@tanstack/react-query": "5.101.0",
    "@trpc/client": "11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "11.17.0",
    "api": "*",
    "app": "*",
    "expo": "~56.0.11",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "moti": "^0.30.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-worklets": "0.8.3",
    "ui": "*"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@lingui/metro-transformer": "6.3.0",
    "@types/react": "19.2.17",
    "babel-plugin-react-compiler": "1.0.0",
    "babel-preset-expo": "~56.0.15",
    "dotenv-cli": "^7.4.2",
    "react-compiler-runtime": "1.0.0",
    "react-refresh": "^0.18.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "NODE_ENV=development node scripts/load-env.js expo start --port 8082",
    "android": "NODE_ENV=development node scripts/load-env.js expo run:android",
    "ios": "NODE_ENV=development node scripts/load-env.js expo run:ios --port 8082",
    "build:android": "NODE_ENV=production node scripts/load-env.js expo run:android",
    "build:ios": "NODE_ENV=production node scripts/load-env.js expo run:ios",
    "eas:build:android": "eas build --platform android",
    "eas:build:ios": "eas build --platform ios",
    "eas:build:all": "eas build --platform all",
    "eas:build:android:profile": "eas build --platform android --profile production",
    "eas:build:ios:profile": "eas build --platform ios --profile production",
    "eas:submit:android": "eas submit --platform android",
    "eas:submit:ios": "eas submit --platform ios",
    "eas:update": "eas update",
    "eas:update:republish": "eas update --branch production --message \"Update\"",
    "eas:configure": "eas build:configure",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test:e2e": "maestro test .maestro/navigation .maestro/auth .maestro/theme .maestro/locale .maestro/integration",
    "test:e2e:device:list": "xcrun simctl list devices && adb devices"
  },
  "main": "index.js",
  "version": "1.0.0",
  "private": true,
  "name": "expo-app"
}
