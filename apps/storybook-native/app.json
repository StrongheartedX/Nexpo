{
  "expo": {
    "name": "storybook-native",
    "slug": "storybook-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "system",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexpo.storybook"
    },
    "android": {
      "package": "com.nexpo.storybook"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "backgroundColor": "#ffffff",
          "resizeMode": "contain"
        }
      ],
      "expo-status-bar"
    ]
  }
}
